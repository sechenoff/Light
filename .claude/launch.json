{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "-w", "apps/api"],
      "port": 4000
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "-w", "apps/web"],
      "port": 3000
    },
    {
      "name": "mockups",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "docs/mockups", "-p", "8090", "-c-1"],
      "port": 8090
    }
  ]
}
