{
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "list_equipment",
        "description": "Получить список оборудования из каталога. Используй для поиска доступного снаряжения по названию или категории.",
        "parameters": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "description": "Поиск по названию оборудования (частичное совпадение)"
            },
            "category": {
              "type": "string",
              "description": "Фильтр по категории (например: Свет, Камеры, Грипы)"
            },
            "limit": {
              "type": "integer",
              "description": "Максимальное число записей (default: 100, max: 200)",
              "default": 100
            }
          },
          "required": [],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "check_availability",
        "description": "Проверить доступность оборудования на указанный период. Используй перед созданием брони чтобы убедиться, что нужное количество свободно.",
        "parameters": {
          "type": "object",
          "properties": {
            "from": {
              "type": "string",
              "format": "date-time",
              "description": "Начало периода (ISO 8601, например: 2026-04-20T10:00:00Z)"
            },
            "to": {
              "type": "string",
              "format": "date-time",
              "description": "Конец периода (ISO 8601)"
            },
            "equipmentId": {
              "type": "string",
              "description": "ID конкретного оборудования для проверки (опционально)"
            }
          },
          "required": ["from", "to"],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "match_equipment_description",
        "description": "Подобрать оборудование из каталога по текстовому описанию. Используй когда пользователь называет оборудование неформально (сленг, сокращения, торговые марки). Возвращает resolved/needsReview/unmatched позиции.",
        "parameters": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "description": "Список позиций для сопоставления",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Название оборудования как сказал пользователь"
                  },
                  "quantity": {
                    "type": "integer",
                    "description": "Количество единиц",
                    "minimum": 1
                  }
                },
                "required": ["name", "quantity"],
                "additionalProperties": false
              },
              "minItems": 1
            }
          },
          "required": ["items"],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "quote_booking",
        "description": "Рассчитать предварительную смету для аренды без создания брони. Используй чтобы узнать итоговую стоимость перед оформлением.",
        "parameters": {
          "type": "object",
          "properties": {
            "client": {
              "type": "object",
              "description": "Данные клиента",
              "properties": {
                "name": { "type": "string", "description": "Имя или название компании" },
                "phone": { "type": "string", "description": "Телефон (опционально)" },
                "email": { "type": "string", "description": "Email (опционально)" }
              },
              "required": ["name"],
              "additionalProperties": false
            },
            "projectName": {
              "type": "string",
              "description": "Название проекта/съёмки"
            },
            "startDate": {
              "type": "string",
              "format": "date-time",
              "description": "Начало аренды (ISO 8601)"
            },
            "endDate": {
              "type": "string",
              "format": "date-time",
              "description": "Конец аренды (ISO 8601)"
            },
            "items": {
              "type": "array",
              "description": "Список оборудования",
              "items": {
                "type": "object",
                "properties": {
                  "equipmentId": { "type": "string", "description": "ID оборудования из каталога" },
                  "quantity": { "type": "integer", "minimum": 1, "description": "Количество" }
                },
                "required": ["equipmentId", "quantity"],
                "additionalProperties": false
              },
              "minItems": 1
            },
            "discountPercent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "Скидка в процентах (опционально)"
            }
          },
          "required": ["client", "projectName", "startDate", "endDate", "items"],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "create_booking_draft",
        "description": "Создать черновик брони. Используй dryRun=true чтобы показать пользователю превью (смету и даты) перед реальным созданием. При dryRun=false бронь записывается в БД со статусом DRAFT.",
        "parameters": {
          "type": "object",
          "properties": {
            "dryRun": {
              "type": "boolean",
              "description": "Если true — вернёт превью без записи в БД (status: DRAFT_PREVIEW, id: null)",
              "default": false
            },
            "client": {
              "type": "object",
              "description": "Данные клиента",
              "properties": {
                "name": { "type": "string", "description": "Имя или название компании (обязательно)" },
                "phone": { "type": "string", "description": "Телефон" },
                "email": { "type": "string", "description": "Email" },
                "comment": { "type": "string", "description": "Доп. примечание о клиенте" }
              },
              "required": ["name"],
              "additionalProperties": false
            },
            "projectName": {
              "type": "string",
              "description": "Название проекта/съёмки"
            },
            "startDate": {
              "type": "string",
              "format": "date-time",
              "description": "Начало аренды (ISO 8601)"
            },
            "endDate": {
              "type": "string",
              "format": "date-time",
              "description": "Конец аренды (ISO 8601)"
            },
            "items": {
              "type": "array",
              "description": "Список оборудования для аренды",
              "items": {
                "type": "object",
                "properties": {
                  "equipmentId": { "type": "string", "description": "ID оборудования" },
                  "quantity": { "type": "integer", "minimum": 1 }
                },
                "required": ["equipmentId", "quantity"],
                "additionalProperties": false
              },
              "minItems": 1
            },
            "discountPercent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "Скидка в процентах"
            },
            "expectedPaymentDate": {
              "type": "string",
              "format": "date-time",
              "description": "Плановая дата оплаты"
            },
            "comment": {
              "type": "string",
              "description": "Комментарий к брони"
            }
          },
          "required": ["client", "projectName", "startDate", "endDate", "items"],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "update_booking",
        "description": "Изменить параметры существующей брони (только DRAFT или CONFIRMED). Используй dryRun=true чтобы показать превью изменений перед применением. При dryRun=false изменения записываются в БД.",
        "parameters": {
          "type": "object",
          "properties": {
            "bookingId": {
              "type": "string",
              "description": "ID брони для изменения"
            },
            "dryRun": {
              "type": "boolean",
              "description": "Если true — вернёт превью без изменения БД",
              "default": false
            },
            "projectName": {
              "type": "string",
              "description": "Новое название проекта"
            },
            "startDate": {
              "type": "string",
              "format": "date-time",
              "description": "Новая дата начала аренды"
            },
            "endDate": {
              "type": "string",
              "format": "date-time",
              "description": "Новая дата окончания аренды"
            },
            "items": {
              "type": "array",
              "description": "Новый список оборудования (заменяет существующий полностью)",
              "items": {
                "type": "object",
                "properties": {
                  "equipmentId": { "type": "string" },
                  "quantity": { "type": "integer", "minimum": 1 }
                },
                "required": ["equipmentId", "quantity"],
                "additionalProperties": false
              },
              "minItems": 1
            },
            "discountPercent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "comment": {
              "type": "string"
            }
          },
          "required": ["bookingId"],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "confirm_booking",
        "description": "Подтвердить черновик брони (DRAFT → CONFIRMED). После подтверждения бронь становится активной и резервирует оборудование.",
        "parameters": {
          "type": "object",
          "properties": {
            "bookingId": {
              "type": "string",
              "description": "ID брони для подтверждения"
            }
          },
          "required": ["bookingId"],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "change_booking_status",
        "description": "Сменить статус брони. Используй для подтверждения (confirm), выдачи (issue), возврата (return) или отмены (cancel).",
        "parameters": {
          "type": "object",
          "properties": {
            "bookingId": {
              "type": "string",
              "description": "ID брони"
            },
            "action": {
              "type": "string",
              "enum": ["confirm", "issue", "return", "cancel"],
              "description": "Действие: confirm (DRAFT→CONFIRMED), issue (CONFIRMED→ISSUED), return (ISSUED→RETURNED), cancel (DRAFT/CONFIRMED→CANCELLED)"
            },
            "expectedPaymentDate": {
              "type": "string",
              "format": "date-time",
              "description": "Плановая дата оплаты (для action=confirm)"
            },
            "paymentComment": {
              "type": "string",
              "description": "Комментарий по оплате"
            }
          },
          "required": ["bookingId", "action"],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "get_debts",
        "description": "Получить список клиентов с задолженностями. Возвращает агрегированные долги: суммы, дни просрочки, разбивку по проектам. Используй когда пользователь спрашивает 'кто мне должен' или 'список долгов'.",
        "parameters": {
          "type": "object",
          "properties": {
            "overdueOnly": {
              "type": "boolean",
              "description": "Если true — показать только просроченных должников (дата платежа прошла)",
              "default": false
            },
            "minAmount": {
              "type": "number",
              "description": "Минимальная сумма долга для включения в список (в рублях)",
              "minimum": 0
            }
          },
          "required": [],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "get_finance_dashboard",
        "description": "Получить финансовую сводку: доходы за день/неделю/месяц, ожидаемые платежи, просроченные брони, прибыль. Используй для общего вопроса 'как дела с финансами'.",
        "parameters": {
          "type": "object",
          "properties": {},
          "required": [],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "get_booking",
        "description": "Получить детали конкретной брони по ID, включая список оборудования, статус оплаты, финансовые события.",
        "parameters": {
          "type": "object",
          "properties": {
            "bookingId": {
              "type": "string",
              "description": "ID брони"
            }
          },
          "required": ["bookingId"],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "list_bookings",
        "description": "Получить список броней. Используй для поиска существующих броней клиента или просмотра активных заказов.",
        "parameters": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "description": "Максимальное число броней (default: 50, max: 200)",
              "default": 50,
              "minimum": 1,
              "maximum": 200
            }
          },
          "required": [],
          "additionalProperties": false
        }
      }
    }
  ]
}
