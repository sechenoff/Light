# Локальная БД (по умолчанию SQLite-файл рядом с проектом)
DATABASE_URL="file:./dev.db"

# CORS для фронтенда
CORS_ORIGIN="http://localhost:3000"

# Порт API
PORT=4000

# По умолчанию PDF использует DejaVu из apps/api/assets/fonts. При необходимости переопределите:
# SMETA_PDF_FONT_TTF="/path/to/DejaVuSans.ttf"
# SMETA_PDF_FONT_BOLD_TTF="/path/to/DejaVuSans-Bold.ttf"

