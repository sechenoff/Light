# Локальная БД (по умолчанию SQLite-файл рядом с проектом)
DATABASE_URL="file:./dev.db"

# CORS для фронтенда
CORS_ORIGIN="http://localhost:3000"

# Порт API
PORT=4000

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Vision provider: mock (по умолчанию, без внешних запросов) | gemini
VISION_PROVIDER=mock

# Google Gemini API — используется при VISION_PROVIDER=gemini и LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# LLM provider для парсинга заявок гаффера: gemini (по умолчанию) | openai | fallback
#   fallback = ChatMock (OPENAI_BASE_URL) с авто-переключением на прямой
#   api.openai.com (OPENAI_FALLBACK_*) при сбое/429/пустом ответе ChatMock.
LLM_PROVIDER=gemini

# OpenAI API — используется при LLM_PROVIDER=openai
# OPENAI_API_KEY обязателен при обращении к api.openai.com напрямую.
# При работе через локальный прокси (ChatMock и т.п.) ключ не нужен —
# прокси использует свою OAuth-сессию; оставьте пустым или "unused".
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL — endpoint OpenAI-совместимого прокси (обход гео-блокировки
# api.openai.com в РФ). Примеры:
#   ChatMock (локальный, ChatGPT Plus OAuth): http://127.0.0.1:8000/v1
#   реселлер-прокси:                          https://api.proxyapi.ru/openai/v1
# Если не задан — SDK идёт напрямую на api.openai.com.
OPENAI_BASE_URL=

# LLM_PROVIDER=fallback: вторая нога (надёжный прямой api.openai.com).
# OPENAI_FALLBACK_API_KEY — настоящий sk-proj ключ (обязателен при fallback).
# OPENAI_FALLBACK_MODEL — модель прямого API (по умолчанию gpt-4o).
# baseURL для этой ноги НЕ задаётся (всегда прямой api.openai.com).
OPENAI_FALLBACK_API_KEY=your_sk_proj_key_here
OPENAI_FALLBACK_MODEL=gpt-4o

# По умолчанию PDF использует DejaVu из apps/api/assets/fonts. При необходимости переопределите:
# SMETA_PDF_FONT_TTF="/path/to/DejaVuSans.ttf"
# SMETA_PDF_FONT_BOLD_TTF="/path/to/DejaVuSans-Bold.ttf"

# Аутентификация по API-ключу (X-API-Key header)
API_KEYS=your_api_key_here
# warn — неавторизованные запросы логируются, но пропускаются (безопасное значение по умолчанию)
# enforce — неавторизованные запросы отклоняются с 401
AUTH_MODE=warn

# ─── Реквизиты организации (для PDF Счёт и Акт) ──────────────────────────────
# Phase 1: берутся из ENV. Phase 2 переедет в /settings/organization (БД).
ORG_NAME="ООО «Световое оборудование»"
ORG_INN="7700000000"
ORG_KPP="770001001"
ORG_ADDRESS="г. Москва, ул. Примерная, д. 1, офис 101"
ORG_PHONE="+7 (495) 000-00-00"
ORG_BANK="АО «Альфа-Банк»"
ORG_BIK="044525593"
ORG_RSCHET="40702810000000000001"
ORG_KSCHET="30101810200000000593"

# DEV ONLY — skip bcrypt password check on /api/auth/login.
# When NODE_ENV !== "production" AND set to "true", any password is accepted for any AdminUser.
# DO NOT enable on production. The deploy.sh sets NODE_ENV=production, which forces this branch off.
DEV_AUTH_BYPASS=false
