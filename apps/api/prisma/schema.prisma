generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum StockTrackingMode {
  COUNT
  UNIT
}

enum BookingStatus {
  DRAFT
  PENDING_APPROVAL
  CONFIRMED
  ISSUED
  RETURNED
  CANCELLED
}

enum BookingPaymentStatus {
  NOT_PAID
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum PaymentDirection {
  INCOME
  EXPENSE
}

enum PaymentRecordStatus {
  PLANNED
  RECEIVED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  OTHER
}

enum ExpenseCategory {
  TRANSPORT
  EQUIPMENT
  CONTRACTORS
  STAFF
  RENT
  REPAIR
  PAYROLL
  PURCHASE
  OTHER
}

enum RepairStatus {
  WAITING_REPAIR
  IN_REPAIR
  WAITING_PARTS
  CLOSED
  WROTE_OFF
}

enum RepairUrgency {
  NOT_URGENT
  NORMAL
  URGENT
}

enum TaskStatus {
  OPEN
  DONE
}

enum InvoiceKind {
  FULL
  DEPOSIT
  BALANCE
  CORRECTION
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL_PAID
  PAID
  OVERDUE
  VOID
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  CONVERTED
  CLOSED
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum UnitStatus {
  AVAILABLE
  ISSUED
  MAINTENANCE
  RETIRED
  MISSING
}

enum ScanOperation {
  ISSUE
  RETURN
}

enum ScanSessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

/// Telegram-пользователь, отправивший фото для анализа
model User {
  id         String   @id @default(cuid())
  telegramId BigInt   @unique
  username   String?
  firstName  String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  analyses Analysis[]
  leads    Lead[]

  @@index([telegramId])
}

/// Результат AI-анализа кадра: описание схемы освещения + список оборудования
model Analysis {
  id     String         @id @default(cuid())
  userId String
  user   User           @relation(fields: [userId], references: [id])

  status AnalysisStatus @default(PENDING)

  /// Telegram file_id исходного фото (для повторной загрузки при необходимости)
  telegramFileId   String
  telegramMimeType String  @default("image/jpeg")

  /// Путь к сохранённому файлу (заполняется после загрузки через storage service)
  storagePath      String?

  /// Заполняются после завершения AI-анализа (DONE)
  description      String?
  equipmentJson    String?
  estimatePerShift Decimal?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead Lead?

  @@index([userId])
  @@index([status])
}

/// Лид — намерение клиента оформить бронь на основе анализа
model Lead {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id])

  analysisId String?    @unique
  analysis   Analysis?  @relation(fields: [analysisId], references: [id])

  /// Бронь, созданная из этого лида (заполняется после перехода в booking-сцену)
  bookingId  String?    @unique
  booking    Booking?   @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  status     LeadStatus @default(NEW)
  comment    String?

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId])
  @@index([status])
}

model Client {
  id        String   @id @default(cuid())
  name      String   @unique
  phone     String?
  email     String?
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@index([name])
}

/// Простые настройки приложения (JSON и др.), например порядок категорий оборудования.
model AppSetting {
  key   String   @id
  value String

  updatedAt DateTime @updatedAt
}

// Парк техники в терминах сметы SvetoBaza (порядок как в Excel):
// 1) Перечень оборудования → name (+ category как группа/раздел)
// 2) Кол-во → totalQuantity
// 3) Стоимость → rentalRatePerShift (за смену)
// Не храним: «Общая стоимость», «Заказ Количество», «Сумма аренды» — только вычисляются при брони/смете.
model Equipment {
  id                String            @id @default(cuid())
  importKey         String            @unique
  stockTrackingMode StockTrackingMode @default(COUNT)
  sortOrder         Int               @default(0)

  category String
  /// Перечень оборудования (наименование позиции)
  name     String
  brand    String?
  model    String?
  comment  String?

  /// Кол-во (единиц на складе / в парке)
  totalQuantity Int @default(0)
  /// Стоимость (ставка аренды за смену)
  rentalRatePerShift Decimal

  rentalRateTwoShifts  Decimal?
  rentalRatePerProject Decimal?

  units        EquipmentUnit[]
  bookingItems BookingItem[]
  slangAliases SlangAlias[]
  importSessionRows  ImportSessionRow[]
  competitorAliases  CompetitorAlias[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([name])
  @@index([sortOrder])
}

model EquipmentUnit {
  id                      String     @id @default(cuid())
  equipmentId             String
  serialNumber            String?    @unique
  internalInventoryNumber String?    @unique
  barcode                 String?    @unique
  barcodePayload          String?    @unique
  status                  UnitStatus @default(AVAILABLE)
  comment                 String?
  createdAt               DateTime   @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  bookingItemUnits BookingItemUnit[]
  scanRecords      ScanRecord[]
  repairs          Repair[]

  @@index([equipmentId])
  @@index([status])
}

model Booking {
  id         String        @id @default(cuid())
  clientId   String
  client     Client        @relation(fields: [clientId], references: [id])

  projectName String
  startDate   DateTime
  endDate     DateTime

  status      BookingStatus @default(DRAFT)
  comment     String?

  discountPercent Decimal?
  totalEstimateAmount Decimal @default(0)
  discountAmount Decimal @default(0)
  finalAmount Decimal @default(0)
  paymentStatus BookingPaymentStatus @default(NOT_PAID)
  expectedPaymentDate DateTime?
  actualPaymentDate DateTime?
  paymentComment String?

  /// Причина последнего отклонения (заполняется при rejectBooking, очищается при submitForApproval).
  rejectionReason String?

  isFullyPaid Boolean @default(false)
  amountPaid Decimal @default(0)
  amountOutstanding Decimal @default(0)

  /// Текст для экспорта сметы (PDF/XLSX), опционально
  estimateOptionalNote            String?
  estimateIncludeOptionalInExport Boolean @default(false)

  /// Transport snapshot — захватывается в момент создания/апдейта
  vehicleId             String?
  vehicle               Vehicle?  @relation(fields: [vehicleId], references: [id])
  vehicleWithGenerator  Boolean   @default(false)
  vehicleShiftHours     Decimal?
  vehicleSkipOvertime   Boolean   @default(false)
  vehicleKmOutsideMkad  Int?
  vehicleTtkEntry       Boolean   @default(false)
  transportSubtotalRub  Decimal?

  estimate Estimate?
  payments Payment[]
  expenses Expense[]
  financeEvents BookingFinanceEvent[]
  sourceRepairs  Repair[]    @relation("RepairSourceBooking")

  items        BookingItem[]
  lead         Lead?
  scanSessions ScanSession[]

  /// Флаг импорта из старых данных: бронь без items, только финансовый остаток
  isLegacyImport Boolean @default(false)

  /// Флаг dual-mode финансов: true = pre-cutoff (старая логика Payment напрямую), false = post-cutoff (Invoice-слой)
  legacyFinance Boolean @default(true)

  invoices       Invoice[]

  /// H5: Дата удержания депозита как штрафа (FORFEIT ветка cancel-with-deposit).
  /// null означает что штраф не применялся.
  forfeitedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  confirmedAt DateTime?

  @@index([startDate])
  @@index([endDate])
  @@index([status])
  @@index([clientId])
  @@index([expectedPaymentDate])
  @@index([paymentStatus])
}

model Payment {
  id String @id @default(cuid())
  bookingId String?
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  amount Decimal
  currency String @default("RUB")
  paymentDate DateTime?
  plannedPaymentDate DateTime?
  paymentMethod PaymentMethod @default(OTHER)
  direction PaymentDirection @default(INCOME)
  status PaymentRecordStatus @default(PLANNED)
  payerName String?
  comment String?

  /// Новые поля для системы ролей (Sprint 1)
  method      PaymentMethod? // синоним paymentMethod для новой системы
  receivedAt  DateTime?      // фактическая дата получения
  note        String?        // примечание (замена comment)
  createdBy   String?        // AdminUser.id

  /// Finance Phase 2: привязка к Invoice + soft-void
  invoiceId   String?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  voidedAt    DateTime?
  voidedBy    String?   // AdminUser.id
  voidReason  String?

  refunds     Refund[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([status])
  @@index([direction])
  @@index([plannedPaymentDate])
  @@index([paymentDate])
  @@index([receivedAt])
  @@index([invoiceId])
}

model Expense {
  id String @id @default(cuid())
  bookingId String?
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  category ExpenseCategory @default(OTHER)
  name String
  amount Decimal
  currency String @default("RUB")
  expenseDate DateTime
  comment String?

  /// Новые поля для системы ролей (Sprint 1)
  description   String?    // расширенное описание
  documentUrl   String?    // ссылка на документ
  linkedRepairId String?   // связанный ремонт
  linkedRepair  Repair?   @relation(fields: [linkedRepairId], references: [id], onDelete: SetNull)
  approved      Boolean    @default(true) // для TECHNICIAN-расходов — нужен approval SUPER_ADMIN
  createdBy     String?    // AdminUser.id

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([category])
  @@index([expenseDate])
  @@index([linkedRepairId])
}

model BookingFinanceEvent {
  id String @id @default(cuid())
  bookingId String
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  eventType String
  statusFrom BookingPaymentStatus?
  statusTo BookingPaymentStatus?
  amountDelta Decimal?
  payloadJson String?
  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([createdAt])
}

// Инвариант: либо equipmentId != null (каталожная позиция),
// либо customName + customUnitPrice заполнены (произвольная позиция).
model BookingItem {
  id          String   @id @default(cuid())
  bookingId   String
  equipmentId String?

  quantity Int

  // Поля произвольной позиции (заполняются при отсутствии equipmentId)
  customName      String?
  customCategory  String?
  customUnitPrice Decimal?

  booking Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  equipment Equipment? @relation(fields: [equipmentId], references: [id])

  unitReservations BookingItemUnit[]

  createdAt DateTime @default(now())

  @@unique([bookingId, equipmentId])
  @@index([equipmentId])
}

model BookingItemUnit {
  id              String    @id @default(cuid())
  bookingItemId   String
  equipmentUnitId String
  returnedAt      DateTime?

  bookingItem   BookingItem   @relation(fields: [bookingItemId], references: [id], onDelete: Cascade)
  equipmentUnit EquipmentUnit @relation(fields: [equipmentUnitId], references: [id])

  @@unique([bookingItemId, equipmentUnitId])
  @@index([equipmentUnitId])
}

model Estimate {
  id              String   @id @default(cuid())
  bookingId       String   @unique
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  currency        String   @default("RUB")
  shifts          Int

  subtotal        Decimal 
  discountPercent Decimal? 
  discountAmount  Decimal  
  totalAfterDiscount Decimal

  commentSnapshot String?
  /// Доп. текст в экспорте (копия из брони при подтверждении)
  optionalNote            String?
  includeOptionalInExport Boolean @default(false)
  /// «1 смена = 24 ч. · …» на момент подтверждения
  hoursSummaryText      String?

  createdAt DateTime @default(now())

  lines EstimateLine[]
}

model EstimateLine {
  id           String @id @default(cuid())
  estimateId   String
  equipmentId  String?

  categorySnapshot String
  nameSnapshot     String
  brandSnapshot    String?
  modelSnapshot    String?

  quantity Int
  unitPrice Decimal 
  lineSum   Decimal 

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

model ScanSession {
  id          String            @id @default(cuid())
  bookingId   String
  booking     Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  workerName  String
  operation   ScanOperation
  status      ScanSessionStatus @default(ACTIVE)
  startedAt   DateTime          @default(now())
  completedAt DateTime?

  scans ScanRecord[]

  @@index([bookingId, operation, status])
}

model ScanRecord {
  id              String   @id @default(cuid())
  sessionId       String
  equipmentUnitId String
  hmacVerified    Boolean  @default(true)
  scannedAt       DateTime @default(now())

  session       ScanSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  equipmentUnit EquipmentUnit @relation(fields: [equipmentUnitId], references: [id], onDelete: Cascade)

  @@unique([sessionId, equipmentUnitId])
  @@index([equipmentUnitId])
}

model WarehousePin {
  id             String    @id @default(cuid())
  name           String    @unique
  pinHash        String
  isActive       Boolean   @default(true)
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

enum SlangAliasSource {
  SEED
  AUTO_LEARNED
  MANUAL_ADMIN
}

/// Подтверждённый жаргонный псевдоним → конкретная позиция каталога.
/// Пополняется только после одобрения администратором.
model SlangAlias {
  id              String           @id @default(cuid())
  phraseNormalized String          /// нормализованная форма (нижний регистр, без спецсимволов)
  phraseOriginal  String           /// оригинальный текст из заявки
  equipmentId     String
  equipment       Equipment        @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  confidence      Float            @default(1.0)
  source          SlangAliasSource @default(AUTO_LEARNED)
  usageCount      Int              @default(1)
  lastUsedAt      DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([phraseNormalized, equipmentId])
  @@index([phraseNormalized])
  @@index([equipmentId])
}

enum SlangCandidateStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ImportSessionType {
  OWN_PRICE_UPDATE
  COMPETITOR_IMPORT
}

enum ImportSessionStatus {
  PARSING
  MATCHING
  REVIEW
  APPLYING
  COMPLETED
  EXPIRED
}

enum DiffAction {
  PRICE_CHANGE
  NEW_ITEM
  REMOVED_ITEM
  QTY_CHANGE
  NO_CHANGE
}

enum DiffRowStatus {
  PENDING
  ACCEPTED
  REJECTED
}

/// Очередь предложенных (но ещё не подтверждённых) жаргонных соответствий.
model SlangLearningCandidate {
  id                    String               @id @default(cuid())
  rawPhrase             String               /// оригинальный текст из заявки гаффера
  normalizedPhrase      String               /// нормализованная форма
  proposedEquipmentId   String?              /// ID позиции каталога (если AI нашёл кандидата)
  proposedEquipmentName String?              /// имя позиции для отображения в админке
  confidence            Float               @default(0.5)
  contextJson           String?              /// JSON: фрагмент заявки и дата для аудита
  status                SlangCandidateStatus @default(PENDING)
  reviewedAt            DateTime?
  reviewedBy            String?              /// имя/пометка того, кто одобрил/отклонил

  createdAt DateTime @default(now())

  @@index([status])
  @@index([normalizedPhrase])
}

model ImportSession {
  id        String              @id @default(cuid())
  type      ImportSessionType
  status    ImportSessionStatus @default(PARSING)
  competitorName  String?
  fileName       String
  fileSize       Int
  columnMapping  String?
  fileBuffer     Bytes?
  totalRows       Int      @default(0)
  matchedRows     Int      @default(0)
  unmatchedRows   Int      @default(0)
  acceptedCount   Int      @default(0)
  rejectedCount   Int      @default(0)
  appliedCount    Int      @default(0)
  aiSummary      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  expiresAt  DateTime
  rows ImportSessionRow[]
  @@index([status])
  @@index([expiresAt])
}

model ImportSessionRow {
  id            String         @id @default(cuid())
  sessionId     String
  session       ImportSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sourceIndex   Int
  sourceName    String
  sourceCategory String?
  sourceBrand   String?
  sourceModel   String?
  sourcePrice   Decimal?
  sourcePrice2  Decimal?
  sourcePriceProject Decimal?
  sourceQty     Int?
  equipmentId   String?
  equipment     Equipment?     @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  matchConfidence Float?
  matchMethod   String?
  action        DiffAction     @default(NO_CHANGE)
  oldPrice      Decimal?
  oldPrice2     Decimal?
  oldPriceProject Decimal?
  oldQty        Int?
  priceDelta    Decimal?
  aiDescription  String?
  matchSource    String?
  status        DiffRowStatus  @default(PENDING)
  @@index([sessionId])
  @@index([equipmentId])
  @@index([status])
}

model CompetitorAlias {
  id              String    @id @default(cuid())
  competitorName  String
  competitorItem  String
  equipmentId     String
  equipment       Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([competitorName, competitorItem])
  @@index([competitorName])
  @@index([equipmentId])
}

enum UserRole {
  SUPER_ADMIN
  WAREHOUSE
  TECHNICIAN
}

model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         UserRole  @default(WAREHOUSE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditEntries AuditEntry[]

  @@index([username])
}

/// Ремонтная карточка на EquipmentUnit
model Repair {
  id              String         @id @default(cuid())
  unitId          String
  unit            EquipmentUnit  @relation(fields: [unitId], references: [id])
  status          RepairStatus   @default(WAITING_REPAIR)
  urgency         RepairUrgency  @default(NORMAL)
  reason          String
  sourceBookingId String?
  sourceBooking   Booking?       @relation("RepairSourceBooking", fields: [sourceBookingId], references: [id], onDelete: SetNull)
  createdBy       String         // AdminUser.id (обычно WAREHOUSE)
  assignedTo      String?        // AdminUser.id (TECHNICIAN)
  partsCost       Decimal        @default(0)
  totalTimeHours  Decimal        @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  closedAt        DateTime?

  workLog  RepairWorkLog[]
  expenses Expense[]

  @@index([unitId])
  @@index([status])
  @@index([assignedTo])
}

/// Запись работ по ремонту (журнал)
model RepairWorkLog {
  id             String   @id @default(cuid())
  repairId       String
  repair         Repair   @relation(fields: [repairId], references: [id], onDelete: Cascade)
  description    String
  timeSpentHours Decimal
  partCost       Decimal  @default(0)
  loggedBy       String   // AdminUser.id
  loggedAt       DateTime @default(now())

  @@index([repairId])
}

/// Транспортное средство для доставки оборудования
model Vehicle {
  id                 String   @id @default(cuid())
  name               String                    // "Ford", "Фотон", "Ивеко"
  slug               String   @unique          // "ford", "foton", "iveco"
  shiftPriceRub      Decimal
  hasGeneratorOption Boolean  @default(false)
  generatorPriceRub  Decimal?
  shiftHours         Int      @default(12)
  overtimePercent    Decimal  @default(10)
  displayOrder       Int      @default(0)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  bookings Booking[]
}

/// Задача (to-do item)
model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(OPEN)
  urgent      Boolean    @default(false)
  dueDate     DateTime?  // date-only semantics; stored as Moscow-midnight UTC (see §1.4)

  createdBy   String     // AdminUser.id (no FK, matches Repair convention)
  assignedTo  String?    // AdminUser.id, null = "unassigned"
  completedBy String?    // AdminUser.id
  completedAt DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, assignedTo])
  @@index([status, dueDate])
  @@index([createdBy, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Finance Phase 2 models
// ─────────────────────────────────────────────────────────────────────────────

/// Счёт (Invoice) — финансовый документ-обязательство, привязанный к броне.
/// Нумерация: LR-YYYY-NNNN (настраивается через OrganizationSettings.invoiceNumberPrefix).
model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique  // LR-2026-0042
  bookingId   String
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  kind        InvoiceKind   // FULL | DEPOSIT | BALANCE | CORRECTION
  status      InvoiceStatus // DRAFT | ISSUED | PARTIAL_PAID | PAID | OVERDUE | VOID
  total       Decimal
  paidAmount  Decimal       @default(0)
  dueDate     DateTime?
  issuedAt    DateTime?
  voidedAt    DateTime?
  voidedBy    String?       // AdminUser.id
  voidReason  String?
  notes       String?
  createdBy   String        // AdminUser.id
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  payments    Payment[]
  refunds     Refund[]

  @@index([bookingId])
  @@index([status])
  @@index([dueDate])
  // H7: @@index([number]) удалён — уже покрыт @unique на поле number
}

/// Возврат денег клиенту. Привязан к Payment и/или Invoice.
model Refund {
  id          String        @id @default(cuid())
  invoiceId   String?
  invoice     Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  paymentId   String?
  payment     Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  bookingId   String?       // для cancel-with-deposit до Invoice
  amount      Decimal
  reason      String
  method      PaymentMethod // переиспользуем существующий enum
  refundedAt  DateTime
  createdBy   String        // AdminUser.id
  createdAt   DateTime      @default(now())

  @@index([invoiceId])
  @@index([bookingId])
  @@index([paymentId])
}

/// Кредит-нота — удержанный депозит как кредит на будущую бронь.
/// Создаётся в cancel-with-deposit flow при выборе ветки «удержать как кредит».
model CreditNote {
  id                 String    @id @default(cuid())
  contactClientId    String    // Client.id
  bookingId          String?   // origin booking (отменённая с депозитом)
  amount             Decimal
  remaining          Decimal   // изначально = amount; уменьшается при применении
  reason             String
  appliedToBookingId String?   // когда применили к следующей броне
  appliedAt          DateTime?
  createdBy          String    // AdminUser.id
  createdAt          DateTime  @default(now())
  expiresAt          DateTime?

  @@index([contactClientId])
  @@index([bookingId])
  @@index([appliedToBookingId])
}

/// Настройки организации — синглтон (id = "singleton").
/// Хранит реквизиты для PDF-счетов и настройки нумерации.
model OrganizationSettings {
  id                   String   @id @default("singleton")
  legalName            String   @default("")
  inn                  String   @default("")
  kpp                  String?
  bankName             String?
  bankBik              String?
  rschet               String?
  kschet               String?
  address              String?
  phone                String?
  email                String?
  invoiceNumberPrefix  String   @default("LR")
  /// Дата отсечения: брони до cutoff → legacyFinance=true, после → false
  migrationCutoffAt    DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Gaffer CRM — полностью изолированный суб-продукт (не зависит от AdminUser)
// ─────────────────────────────────────────────────────────────────────────────

enum GafferContactType {
  CLIENT
  TEAM_MEMBER
  VENDOR
}

enum GafferProjectStatus {
  OPEN
  ARCHIVED
}

enum GafferPaymentDirection {
  IN  // от клиента к гафферу
  OUT // от гаффера к члену команды
}

model GafferUser {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String?
  passwordHash          String?
  authProvider          String    @default("PASSWORD") // PASSWORD | GOOGLE | TELEGRAM
  providerSubject       String? // Google `sub` или Telegram user_id (для будущих OAuth-провайдеров)
  onboardingCompletedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  contacts       GafferContact[]
  projects       GafferProject[]
  paymentMethods GafferPaymentMethod[]
}

model GafferContact {
  id           String            @id @default(cuid())
  gafferUserId String
  type         GafferContactType
  name         String
  phone        String?
  telegram     String? // username без @
  note         String? // свободный текст (роль, напр. "осветитель")
  isArchived   Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  shiftHours          Int?    @default(10)   // продолжительность смены в часах (по умолчанию 10)
  rateCardId          String?               // ссылка на внешний рейт-кард (опционально)
  rateCardPosition    String?               // должность в рейт-карде
  shiftRate           Decimal @default(0)    // базовая ставка за смену (10 ч)
  overtimeTier1Rate   Decimal @default(0)    // тариф за час переработки, 1–8 ч сверх смены
  overtimeTier2Rate   Decimal @default(0)    // тариф за час, 9–14 ч сверх смены
  overtimeTier3Rate   Decimal @default(0)    // тариф за час, 15+ ч сверх смены
  roleLabel           String?                // "Best Boy", "Key Grip", "Gaffer", "Осветитель / Grip", "Пультовик", "DIT"

  gafferUser       GafferUser            @relation(fields: [gafferUserId], references: [id], onDelete: Cascade)
  clientProjects   GafferProject[]       @relation("ProjectClient")
  memberships      GafferProjectMember[]
  paymentsAsMember GafferPayment[]       @relation("PaymentMember")

  @@index([gafferUserId, type, isArchived])
}

model GafferPaymentMethod {
  id           String   @id @default(cuid())
  gafferUserId String
  name         String // "Тинькофф карта", "Сбер карта", "Счёт ИП", "Наличные"
  isDefault    Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  gafferUser GafferUser      @relation(fields: [gafferUserId], references: [id], onDelete: Cascade)
  payments   GafferPayment[]

  @@unique([gafferUserId, name])
  @@index([gafferUserId])
}

model GafferProject {
  id               String              @id @default(cuid())
  gafferUserId     String
  title            String // "Клип «Синяя волна»"
  clientId         String
  shootDate        DateTime // единственная дата съёмки для MVP
  clientPlanAmount  Decimal             @default(0) // договорная сумма с заказчиком — полный доход гаффера за проект
  clientDueAt       DateTime?
  lightBudgetAmount Decimal             @default(0) // бюджет на свет (rental gear) — вычитается из дохода
  status            GafferProjectStatus @default(OPEN)
  note             String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  gafferUser GafferUser            @relation(fields: [gafferUserId], references: [id], onDelete: Cascade)
  client     GafferContact         @relation("ProjectClient", fields: [clientId], references: [id], onDelete: Restrict)
  members    GafferProjectMember[]
  payments   GafferPayment[]

  @@index([gafferUserId, status])
  @@index([clientId])
}

model GafferProjectMember {
  id            String   @id @default(cuid())
  projectId     String
  contactId     String
  plannedAmount Decimal  @default(0)
  dueAt         DateTime?
  roleLabel     String? // "осветитель, водит грузовик"
  createdAt     DateTime @default(now())

  project GafferProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact GafferContact @relation(fields: [contactId], references: [id], onDelete: Restrict)

  @@unique([projectId, contactId])
  @@index([contactId])
}

model GafferPayment {
  id              String                 @id @default(cuid())
  projectId       String
  direction       GafferPaymentDirection
  amount          Decimal
  paidAt          DateTime // date-only семантика, хранится как UTC-полночь
  paymentMethodId String?
  memberId        String? // обязателен при direction=OUT, null для IN
  comment         String?
  createdAt       DateTime               @default(now())

  project GafferProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  method  GafferPaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  member  GafferContact?       @relation("PaymentMember", fields: [memberId], references: [id], onDelete: SetNull)

  @@index([projectId, direction])
  @@index([memberId])
  @@index([paidAt])
}

// ─────────────────────────────────────────────────────────────────────────────

/// Аудит-лог изменений критичных сущностей
model AuditEntry {
  id         String    @id @default(cuid())
  userId     String
  user       AdminUser @relation(fields: [userId], references: [id])
  action     String    // e.g. "BOOKING_BACKDATE_EDIT", "PAYMENT_DELETE"
  entityType String    // "Booking" | "Payment" | "Expense" | "Unit" | "Client" | "Repair" | "AdminUser"
  entityId   String
  before     String?   // JSON snapshot (diff-relevant fields only)
  after      String?   // JSON snapshot
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([entityType, createdAt])
}
